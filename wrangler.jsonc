{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "f1-widget-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-14",
  "workers_dev": true,
  "kv_namespaces": [
    {
      "binding": "F1_CACHE",
      "id": "90d1917698cf4d4f83a02551f4388cf8"
    }
  ],
  "vars": {
    "JOLPICA_BASE_URL": "https://api.jolpi.ca/ergast/f1/",
    "UPSTREAM_TIMEOUT_MS": "5000"
  },
  "observability": {
    "enabled": true
  }
}
